# X API v2 — app-only bearer token from developer.x.com (read access to public timelines)
X_BEARER_TOKEN=

# GitHub token with contents read/write on YOUR skill repo (fine-grained PAT recommended)
GITHUB_TOKEN=

# Vercel AI Gateway auth for local dev. On Vercel deployments this is provisioned
# automatically as VERCEL_OIDC_TOKEN — run `vercel env pull` locally to refresh it.
AI_GATEWAY_API_KEY=
